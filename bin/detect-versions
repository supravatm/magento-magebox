#!/usr/bin/env bash
#
# bin/detect-versions [--check] [edition] [version]
#
# Generates compose.versions.yaml — a layered image-tag override file — by
# matching the installed Magento/Mage-OS version against compose/lib/versions.tsv.
#
# Usage modes:
#
#   bin/detect-versions community 2.4.9
#     Fast path: edition/version provided explicitly. Used by bin/download
#     before containers boot.
#
#   bin/detect-versions
#     Auto-resolve mode. Edition comes from src/composer.json's package name,
#     version comes from bin/magento-version. Used by bin/setup.
#
#   bin/detect-versions --check
#     Read-only. Compares disk content to expected content. Exits non-zero on
#     drift (or if no compose.versions.yaml exists but one would be generated).
#     Used by bin/start as a pre-flight warning.
#
# Failure semantics: any unresolved input (missing edition, unknown version,
# no matching row) prints a non-fatal warning and exits 0 without writing a
# file. Callers (bin/download, bin/setup) keep running with compose.yaml
# defaults unchanged.

# shellcheck source=../lib/versions.sh
. "$(dirname "$0")/../lib/versions.sh"

OUTPUT_FILE="compose.versions.yaml"
CHECK_MODE=0
QUIET_MODE=0
EDITION_ARG=""
VERSION_ARG=""

while [ $# -gt 0 ]; do
  case "$1" in
    --check)
      CHECK_MODE=1
      shift
      ;;
    --quiet|-q)
      # Used by automated callers (bin/setup safety-net) to suppress
      # "could not resolve" warnings when there's nothing to detect yet.
      # Manual invocations still get the warning.
      QUIET_MODE=1
      shift
      ;;
    -h|--help)
      sed -n '3,28p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *)
      if [ -z "$EDITION_ARG" ]; then
        EDITION_ARG="$1"
      elif [ -z "$VERSION_ARG" ]; then
        VERSION_ARG="$1"
      fi
      shift
      ;;
  esac
done

YELLOW='\033[0;33m'
NC='\033[0m'

warn() {
  printf "${YELLOW}detect-versions: %s${NC}\n" "$1" >&2
}

# Normalize edition label from a bin/download-style edition arg or from a
# composer.json package name.
# Inputs accepted: community, enterprise, mageos, magento, mage-os, plus
# package names like magento/project-community-edition or
# mage-os/project-community-edition.
normalize_edition() {
  local raw="$1"
  case "$raw" in
    magento|community|enterprise|magento/*) printf 'magento\n' ;;
    mage-os|mageos|mage-os/*)              printf 'mage-os\n' ;;
    *)                                     printf '%s\n' "$raw" ;;
  esac
}

resolve_edition() {
  if [ -n "$EDITION_ARG" ]; then
    normalize_edition "$EDITION_ARG"
    return 0
  fi
  if [ -f "src/composer.json" ]; then
    # Pull the "name" field from composer.json with a portable sed/grep pair —
    # no jq/yq dependency, since this script runs on the host before any
    # container is guaranteed to exist.
    local pkg
    pkg="$(grep -m1 '"name"' src/composer.json | sed -E 's/.*"name"[^"]*"([^"]+)".*/\1/')"
    if [ -n "$pkg" ]; then
      normalize_edition "$pkg"
      return 0
    fi
  fi
  return 1
}

resolve_version() {
  if [ -n "$VERSION_ARG" ]; then
    printf '%s\n' "$VERSION_ARG"
    return 0
  fi
  if [ -x "bin/magento-version" ]; then
    local v
    v="$(bin/magento-version 2>/dev/null)"
    case "$v" in
      ''|Failed*) return 1 ;;
      *) printf '%s\n' "$v"; return 0 ;;
    esac
  fi
  return 1
}

EDITION="$(resolve_edition)" || {
  # Stay silent in --check (pre-flight has nothing to verify) and --quiet
  # (automated callers like bin/setup's safety net). Manual invocations
  # still get the warning so the user knows why nothing happened.
  { [ "$CHECK_MODE" = "1" ] || [ "$QUIET_MODE" = "1" ]; } && exit 0
  warn "could not resolve edition (no arg given, src/composer.json missing or unreadable). Skipping."
  exit 0
}
VERSION="$(resolve_version)" || {
  { [ "$CHECK_MODE" = "1" ] || [ "$QUIET_MODE" = "1" ]; } && exit 0
  warn "could not resolve version (no arg given, bin/magento-version returned nothing). Skipping."
  exit 0
}

ROW="$(versions_lookup "$EDITION" "$VERSION")" || {
  warn "no row in compose/lib/versions.tsv matches edition='$EDITION' version='$VERSION'. Using compose.yaml defaults."
  exit 0
}

IFS=$'\t' read -r PHP_TAG OS_TAG NGINX_TAG DB_TAG RMQ_TAG CACHE_TAG _COMPOSER_TAG <<< "$ROW"

generate_yaml() {
  cat <<EOF
# Generated by bin/detect-versions — do not edit by hand.
# Regenerate with: bin/detect-versions [edition] [version]
# Source matrix:  compose/lib/versions.tsv (edition=$EDITION, version=$VERSION)
#
# Load order (later wins): compose.yaml < compose.healthcheck.yaml <
# compose.dev.yaml < compose.versions.yaml < compose.override.yaml.
# To override any of these pins, edit compose.override.yaml.

services:
  phpfpm:
    image: markoshust/magento-php:$PHP_TAG
  phpfpm-xdebug:
    image: markoshust/magento-php:${PHP_TAG/-fpm-/-fpm-xdebug-}
  app:
    image: markoshust/magento-nginx:$NGINX_TAG
  opensearch:
    image: markoshust/magento-opensearch:$OS_TAG
  db:
    image: $DB_TAG
  rabbitmq:
    image: markoshust/magento-rabbitmq:$RMQ_TAG
  redis:
    image: $CACHE_TAG
EOF
}

EXPECTED="$(generate_yaml)"

if [ "$CHECK_MODE" = "1" ]; then
  if [ ! -f "$OUTPUT_FILE" ]; then
    warn "no $OUTPUT_FILE on disk; expected pins for $EDITION $VERSION would be:"
    printf '%s\n' "$EXPECTED" >&2
    exit 1
  fi
  if [ "$EXPECTED" != "$(cat "$OUTPUT_FILE")" ]; then
    warn "$OUTPUT_FILE is out of date for $EDITION $VERSION."
    warn "Run bin/detect-versions (no args) to regenerate."
    exit 1
  fi
  exit 0
fi

printf '%s\n' "$EXPECTED" > "$OUTPUT_FILE"
printf 'Wrote %s for %s %s.\n' "$OUTPUT_FILE" "$EDITION" "$VERSION"
