#!/usr/bin/env bash

# shellcheck source=../lib/versions.sh
. "$(dirname "$0")/../lib/versions.sh"

# Define colors for formatting
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

show_header() {
    echo -e "${GREEN}============================================${NC}"
    echo -e "${GREEN}   Magento 2 System Requirements Checker${NC}"
    echo -e "${GREEN}============================================${NC}"
    echo
}

show_version_groups() {
    echo -e "${BLUE}Available version groups:${NC}"
    echo " 1) Magento 2.4.9.x"
    echo " 2) Magento 2.4.8.x"
    echo " 3) Magento 2.4.7.x"
    echo " 4) Magento 2.4.6.x"
    echo " 5) Magento 2.4.5.x"
    echo " 6) Magento 2.4.4.x"
    echo " 7) Magento 2.4.3.x  (PHP 7.4, EOL)"
    echo " 8) Magento 2.4.2.x  (PHP 7.4, EOL)"
    echo " 9) Mage-OS 3.0.x"
    echo "10) Mage-OS 2.x"
    echo "11) Mage-OS 1.x"
    echo
}

# Render a requirements block for a version group by reading compose/lib/versions.tsv.
# Both bin/detect-versions and bin/check-dependencies consume the same source table
# so they can't drift.
show_requirements_from_tsv() {
    local title="$1"
    local edition="$2"
    local sample_version="$3"

    local row
    row="$(versions_lookup "$edition" "$sample_version")" || {
        echo -e "${RED}No row in compose/lib/versions.tsv matches edition='$edition' version='$sample_version'${NC}"
        return 1
    }

    local php os nginx db rmq cache composer
    IFS=$'\t' read -r php os nginx db rmq cache composer <<< "$row"

    echo -e "${GREEN}System Requirements for ${title}:${NC}"
    echo -e "${YELLOW}Pinned by bin/detect-versions (highest supported version wins):${NC}"
    echo "• PHP image:        markoshust/magento-php:$php"
    echo "• Composer:         $composer"
    echo "• Database:         $db"
    echo "• OpenSearch image: markoshust/magento-opensearch:$os"
    echo "• Cache/Session:    $cache"
    echo "• Message Queue:    markoshust/magento-rabbitmq:$rmq"
    echo "• Web Server:       markoshust/magento-nginx:$nginx"
    echo
    echo -e "${BLUE}Source: compose/lib/versions.tsv${NC}"
}

show_additional_info() {
    echo -e "${BLUE}Additional Information:${NC}"
    echo "• Adobe Commerce system requirements: https://experienceleague.adobe.com/docs/commerce-operations/installation-guide/system-requirements.html"
    echo "• Mage-OS system requirements:        https://mage-os.org/get-started/system-requirements/"
    echo "• Magento DevDocs:                    https://developer.adobe.com/commerce/docs/"
    echo "• Security best practices:            https://experienceleague.adobe.com/docs/commerce-operations/implementation-playbook/best-practices/security/overview.html"
}

clear
show_header

while true; do
    show_version_groups
    echo -e "${YELLOW}Options:${NC}"
    echo "1-11) Select version group"
    echo "i) Additional Information"
    echo "q) Quit"
    echo
    read -r -p "Enter your choice: " choice

    case $choice in
        q|Q)
            echo -e "${GREEN}Thank you for using the Magento System Requirements Checker!${NC}"
            exit 0
            ;;
        i|I)
            clear
            show_additional_info
            ;;
        1)  clear; show_requirements_from_tsv "Magento 2.4.9.x" magento 2.4.9 ;;
        2)  clear; show_requirements_from_tsv "Magento 2.4.8.x" magento 2.4.8 ;;
        3)  clear; show_requirements_from_tsv "Magento 2.4.7.x" magento 2.4.7 ;;
        4)  clear; show_requirements_from_tsv "Magento 2.4.6.x" magento 2.4.6 ;;
        5)  clear; show_requirements_from_tsv "Magento 2.4.5.x" magento 2.4.5 ;;
        6)  clear; show_requirements_from_tsv "Magento 2.4.4.x" magento 2.4.4 ;;
        7)  clear; show_requirements_from_tsv "Magento 2.4.3.x" magento 2.4.3 ;;
        8)  clear; show_requirements_from_tsv "Magento 2.4.2.x" magento 2.4.2 ;;
        9)  clear; show_requirements_from_tsv "Mage-OS 3.0.x"   mage-os 3.0.0 ;;
        10) clear; show_requirements_from_tsv "Mage-OS 2.x"     mage-os 2.3.0 ;;
        11) clear; show_requirements_from_tsv "Mage-OS 1.x"     mage-os 1.3.0 ;;
        *)
            echo -e "${RED}Invalid choice. Please try again.${NC}"
            ;;
    esac

    echo
    read -r -p "Press Enter to continue..."
    clear
done
